{
  "name": "memran/marwa-router",
  "description": "Attribute + fluent routing over league/route with PSR-7/15/16 support.",
  "type": "library",
  "keywords": [
    "router",
    "routing",
    "league-route",
    "php8-attributes",
    "psr-7",
    "psr-15",
    "psr-16"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Mohammad Emran",
      "role": "Maintainer"
    }
  ],
  "require": {
    "php": "^8.2",
    "laminas/laminas-diactoros": "^3",
    "laminas/laminas-httphandlerrunner": "^2",
    "league/route": "^6",
    "psr/container": "^1 || ^2",
    "psr/log": "^1 || ^2 || ^3",
    "psr/simple-cache": "^1 || ^2 || ^3"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3",
    "phpbench/phpbench": "^1.7",
    "phpstan/phpstan": "^2",
    "phpunit/phpunit": "^10 || ^11"
  },
  "autoload": {
    "psr-4": {
      "Marwa\\Router\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Marwa\\Router\\Tests\\": "tests/",
      "Marwa\\Router\\Benchmarks\\": "benchmarks/",
      "Examples\\": "examples/"
    }
  },
  "bin": [
    "bin/routes-dump.php",
    "bin/routes-build-cache.php"
  ],
  "scripts": {
    "test": "phpunit --configuration phpunit.xml.dist",
    "test:coverage": "phpunit --configuration phpunit.xml.dist --coverage-text",
    "analyse": "phpstan analyse --configuration phpstan.neon.dist --no-progress --debug --memory-limit=1G",
    "cs": "php-cs-fixer fix --dry-run --diff --verbose --sequential",
    "cs-fix": "php-cs-fixer fix --verbose --sequential",
    "lint": "@cs",
    "fix": "@cs-fix",
    "validate:composer": "composer validate --strict",
    "ci": [
      "@validate:composer",
      "@analyse",
      "@test",
      "@lint"
    ],
    "benchmark": "phpbench run --report=default --output=ansi"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "minimum-stability": "stable",
    "prefer-stable": true,
    "platform": {
      "php": "8.2.0"
    }
  }
}
